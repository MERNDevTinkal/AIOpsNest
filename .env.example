# Replace these placeholder values before running in production
# Use secure storage for secrets (AWS Secrets Manager, SSM, or IRSA for EKS)
MONGO_URI=
PORT=3000
JWT_ACCESS_TOKEN_SECRET=
JWT_REFRESH_TOKEN_SECRET=
EMAIL_ENABLED=false
EMAIL_FROM="no-reply@your-domain.com"

# SMTP placeholder (used if EMAIL_ENABLED=true). Leave blank if using SES.
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=

# AWS-related (optional)
AWS_REGION=us-east-1
BUCKET_NAME=
SNS_TOPIC_ARN=
ECR_REPO=
AWS_ACCOUNT_ID=

# AI-Ops
GH_TOKEN=
