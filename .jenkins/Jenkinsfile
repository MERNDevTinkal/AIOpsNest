// Declarative Jenkins pipeline template (Groovy)
// Place this as a template and include/extend in per-service Jenkinsfiles
pipeline {
  agent any
  environment {
    AWS_REGION = credentials('aws-region')
    AWS_ACCESS_KEY_ID = credentials('aws-access-key-id')
    AWS_SECRET_ACCESS_KEY = credentials('aws-secret-access-key')
    ECR_REGISTRY = credentials('ecr-registry')
  }
  stages {
    stage('Checkout') {
      steps { checkout scm }
    }

    stage('Build & Test (.NET)') {
      steps {
        dir('apps/dotnet/auth') {
          sh 'dotnet restore'
          sh 'dotnet build --configuration Release'
          sh 'dotnet test --no-build'
        }
      }
    }

    stage('Docker Build & Push') {
      steps {
        script {
          def repo = "${ECR_REGISTRY}/auth"
          sh "$(aws ecr get-login-password --region ${AWS_REGION}) | docker login --username AWS --password-stdin ${ECR_REGISTRY}"
          sh "docker build -t ${repo}:$GIT_COMMIT -f apps/dotnet/auth/Dockerfile apps/dotnet/auth"
          sh "docker push ${repo}:$GIT_COMMIT"
        }
      }
    }

    stage('Terraform Plan') {
      steps {
        dir('terraform') {
          sh 'terraform init'
          sh 'terraform plan -var-file=terraform/terraform.tfvars'
        }
      }
    }

    stage('Manual Approval & Terraform Apply') {
      when { branch 'main' }
      steps {
        input message: 'Approve apply to production?'
        dir('terraform') {
          sh 'terraform apply -auto-approve -var-file=terraform/terraform.tfvars'
        }
      }
    }
  }
  post {
    always { echo 'Pipeline finished' }
    failure { echo 'Pipeline failed' }
  }
}
