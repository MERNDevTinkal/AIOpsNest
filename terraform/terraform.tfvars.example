region = "us-east-1"
cluster_name = "nest-auth-cluster"
vpc_cidr = "10.0.0.0/16"
public_subnets = ["10.0.1.0/24", "10.0.2.0/24", "10.0.3.0/24"]
private_subnets = ["10.0.11.0/24", "10.0.12.0/24", "10.0.13.0/24"]
node_instance_type = "t3.medium"
node_capacity = 2
mq_broker_name = "auth-rabbitmq"
mq_instance_type = "mq.t3.micro"
mq_admin_user = "admin"
# Don't check actual passwords into source control. Use SSM/Secrets Manager or provide via CI.
# mq_admin_password = "super-secure-password"
